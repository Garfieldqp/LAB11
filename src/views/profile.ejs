<!DOCTYPE html>
<html>
<head>
<title>Profile</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen flex items-center justify-center bg-[#FFF8E7]">

<div class="bg-white w-[420px] p-10 rounded-2xl shadow-xl">

<h1 class="text-3xl font-bold text-center mb-6 text-[#835C2D]">
Profile
</h1>

<div class="space-y-4">

<div class="bg-[#95BBEA] p-4 rounded-lg">
<p class="text-sm text-gray-700">User ID</p>
<p class="font-semibold text-gray-900"><%= user.userId %></p>
</div>

<div class="bg-[#CBEEFD] p-4 rounded-lg">
<p class="text-sm text-gray-700">Email</p>
<p class="font-semibold text-gray-900"><%= user.email %></p>
</div>

</div>

<form method="POST" action="/logout" class="mt-8">
<button
class="w-full bg-[#930500] text-white py-3 rounded-lg hover:opacity-90 transition font-semibold">
Logout
</button>
</form>

</div>

</body>
</html>